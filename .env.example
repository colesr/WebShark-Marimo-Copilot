# Copy to .env and fill in. .env is gitignored.
# Only needed for backend="anthropic"; the default claude-cli backend uses
# your Claude Code subscription and ignores this key.
ANTHROPIC_API_KEY=sk-ant-...

# To override the model or effort, pass model=/effort= to planner_widget()
# or plan() (see README "Tuning the wait"). The default is claude-opus-4-8.
